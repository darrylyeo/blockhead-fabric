DATABASE_URL=postgres://blockhead:blockhead@localhost:5432/blockhead
# Publisher defaults to the local Fabric server brought up by `pnpm service:fabric:up`.
FABRIC_URL=http://localhost:2000/fabric
# FABRIC_ADMIN_KEY=changeme

# Optional: ingest only the last N blocks (e.g. 50). Omit to use checkpoint or INGEST_START_BLOCK.
# INGEST_RECENT_BLOCKS_ONLY=50
# Ingest needs a working Ethereum mainnet WebSocket RPC. If you see EPROTO/SSL or 404, try another.
RPC_WSS_URL=wss://ethereum.publicnode.com
# RPC_WSS_URL=wss://eth.llamarpc.com
# RPC_WSS_URL=wss://mainnet.rpc.buidlguidl.com
# RPC_WSS_URL=wss://rpc.ankr.com/eth
# RPC_WSS_URL=wss://eth.drpc.org
# RPC_WSS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_WSS_URL=wss://mainnet.infura.io/ws/v3/YOUR_KEY
